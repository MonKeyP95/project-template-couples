# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored; `.env.example` is committed as a template.

# Supabase ------------------------------------------------------------
# From your Supabase project: Settings -> API
# Note: Supabase renamed the public key from "anon key" to "publishable key"
# in late 2025. Newer projects show "publishable key" in the dashboard.
# Either name works as the value — both are the same JWT.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Never expose to the browser. Add this only when a Server Action
# or Route Handler needs admin privileges (we don't, yet — leave blank for MVP).
# SUPABASE_SECRET_KEY=
